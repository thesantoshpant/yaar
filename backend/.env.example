# Copy to .env and fill in. The app runs WITHOUT these (mock mode), but real keys unlock live AI.

# --- Gemini access: pick ONE path ---
#
# Path A (simplest): Google AI Studio API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
#
# Path B (recommended for prod): Vertex AI, so usage is billed to your Google Cloud
# project and credit. Set GEMINI_USE_VERTEX=true and your project; then authenticate the
# machine with `gcloud auth application-default login` (or set GOOGLE_APPLICATION_CREDENTIALS
# to a service-account JSON). No GEMINI_API_KEY needed on this path.
GEMINI_USE_VERTEX=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Optional model overrides. Pro is used for the flagship visa report; flash for chat/speed.
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio

# US Dept of Education College Scorecard API key (free: https://api.data.gov/signup/)
COLLEGE_SCORECARD_API_KEY=

# MongoDB connection string. Without it, the app uses an in-memory store (data resets on restart).
# Example: mongodb://localhost:27017/yaar  or a MongoDB Atlas URI
MONGODB_URI=

# Google sign-in. Without these, auth is disabled and the app works in guest mode.
# Create an OAuth 2.0 Client ID (Web) at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
# Any long random string; used to sign session tokens.
JWT_SECRET=

# Agentic company autonomy. dry_run (default, logs only) | assist (outbound needs approval) | live (executes).
# Keep dry_run for dev. Only set live once integrations + guardrails are ready.
YAAR_AUTONOMY_MODE=dry_run
# Admin token for the /api/ops console. REQUIRED once autonomy is not dry_run.
ADMIN_TOKEN=
# Safety caps for the agentic company.
MAX_EXTERNAL_ACTIONS_PER_DAY=100
MAX_AGENT_RUNS_PER_DAY=300

# Spend protection (all optional; strict defaults shown). The daily dollar caps are
# the final backstop; the per-IP rate tiers keep one user from eating the budget.
# DAILY_HARD_CAP_USD=8
# PER_USER_DAILY_CAP_USD=0.5
# MAX_CRON_FANOUT=300
# RATE_AI_PER_MIN=30
# RATE_AI_PER_HOUR=150
# RATE_AI_PER_DAY=500
# RATE_HEAVY_PER_MIN=8
# RATE_HEAVY_PER_HOUR=50
# RATE_HEAVY_PER_DAY=150
# RATE_CREATE_PER_MIN=5
# RATE_CREATE_PER_DAY=30
# Email (Resend) for agent-sent email. Without these, email actions are simulated.
RESEND_API_KEY=
RESEND_FROM=
# Where agent emails go when no specific recipient is set (e.g. your inbox for testing).
NOTIFY_EMAIL=

# Server
PORT=4000
# Public URL of the frontend (used to build parent share links)
PUBLIC_URL=http://localhost:5173
# Comma-separated allowed origins for CORS (frontend dev server)
CORS_ORIGINS=http://localhost:5173
